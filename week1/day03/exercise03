# Exercise 1
# Ask the user for two numbers and print all four artithmetic results.

print("Input two numbers to see the results of\n-Addition!\n-Subtraction!\n-Multiplication!\n-Division!\n")
a = int(input("Enter first number: \t"))
b = int(input("Enter second number: \t"))

add = a + b
sub = a - b
mult = a * b
div = a / b

print(f"\n\n{a} +  {b} = {add}")
print(f"{a} -  {b} = {sub}")
print(f"{a} *  {b} = {mult}")
print(f"{a} /  {b} = {div}")

