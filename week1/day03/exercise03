# Exercise 3
# Tip Calculator

print("\n\n----BONUS Exercise----")
print("Tip Calulator")
check = float(input("Total bill: \t\t"))
grat = float(input("Tip %: \t\t\t"))
people  = int(input("Number of payers: \t"))

split = (check + (check * grat / 100)) / people
print(f"\n\nFor a bill of {check}, with {people} people paying and leaving a {grat}% tip, each person should pay ${split:.2f}.")